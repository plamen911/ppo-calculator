{
  "name": "ppo-calculator",
  "version": "1.0.0",
  "description": "Калкулатор за план за гасене на пожар (ПГП)",
  "author": "PPO",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/generate-icons.mjs",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win --x64",
    "pack:win": "vite build && electron-builder --win --x64 --dir",
    "build:electron:win7": "node scripts/build-electron-win7.mjs",
    "dist:win7": "vite build --mode win7 && node scripts/build-electron-win7.mjs && electron-builder --win --x64 --config electron-builder-win7.yml",
    "pack:win7": "vite build --mode win7 && node scripts/build-electron-win7.mjs && electron-builder --win --x64 --dir --config electron-builder-win7.yml"
  },
  "dependencies": {
    "katex": "^0.16.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.8",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.4"
  },
  "build": {
    "appId": "bg.ppo.calculator",
    "productName": "Калкулатор за план за пожарогасене",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "executableName": "ppo-calc",
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "ppo-calc-setup.${ext}"
    },
    "portable": {
      "artifactName": "ppo-calc.${ext}"
    }
  }
}
